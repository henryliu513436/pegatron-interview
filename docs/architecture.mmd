%% 系統架構圖 — Smart Factory Alert Agent
%% 匯出方式：貼進 https://mermaid.live → Actions → PNG → 存成 docs/architecture.png
%%
%% 註：config.py 為單一設定來源，被全部 11 個模組引用。
%%     為維持可讀性，圖中不逐一畫出這 11 條低資訊量的連線。

graph TD
    MAIN["main.py — CLI 入口／模式切換"]

    MAIN --> AGENT["agent.py — 管線協調"]
    MAIN --> LLM["llm_advisor.py — LLM 建議"]
    MAIN --> OUT["output.py — 告警輸出"]
    MAIN --> EVAL["evaluate.py — 量化評估"]

    subgraph PIPE["資料管線（由 agent.py 依序呼叫）"]
        direction LR
        GEN["generate_data.py"] --> PRE["preprocess.py"]
        PRE --> FEAT["features.py"]
        FEAT --> RULE["rule_detector.py"]
        FEAT --> ML["ml_detector.py"]
        RULE --> ENS["ensemble.py"]
        ML --> ENS
    end

    AGENT --> PIPE
